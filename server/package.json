{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsup src/server.ts --format esm --clean",
    "start": "node --env-file=.env dist/server.js",
    "make-migrations": "npx drizzle-kit generate",
    "migrate": "npx drizzle-kit migrate",
    "apply-migration": "npx drizzle-kit push",
    "formatter": "npx prettier --write ."
  },
  "dependencies": {
    "@envelop/graphql-jit": "^11.1.1",
    "@fastify/cors": "^11.2.0",
    "@pothos/core": "^4.12.0",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.21.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.12.1",
    "resend": "^6.12.0",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/pino": "^7.0.4",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  }
}
