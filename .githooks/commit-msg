#!/usr/bin/env bash

COMMIT_MSG_FILE=$1

# 1. Read the message, remove Windows carriage returns, and get the first line
COMMIT_MSG=$(tr -d '\r' < "$COMMIT_MSG_FILE" | head -n 1)

# 2. Define types and the regex (No space before the colon!)
TYPES="feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert"
# This regex is strict: type, optional (scope), optional !, colon, space, description
REGEXP="^($TYPES)(\([a-zA-Z0-9_.-]+\))?(!)?:[[:space:]].+$"

# 3. Use grep to validate the message
if ! echo "$COMMIT_MSG" | grep -qE "$REGEXP"; then
    echo "------------------------------------------------------------------"
    echo "ERROR: Invalid Commit Message Format"
    echo "------------------------------------------------------------------"
    echo "Your message: \"$COMMIT_MSG\""
    echo "Expected: <type>(scope): <description>"
    echo "Valid types: $TYPES"
    echo "------------------------------------------------------------------"
    exit 1
fi

exit 0